<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="A_Simple_Recorder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:A_Simple_Recorder"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="A Simple Recorder">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left side: Preview area -->
        <Border Grid.Column="0" Background="Black" Margin="10">
            <Grid x:Name="PreviewArea">
                <!-- Participant thumbnails at top -->
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Top" 
                            HorizontalAlignment="Center" 
                            Spacing="5" 
                            Margin="10"
                            x:Name="ThumbnailsPanel">
                    <!-- Thumbnails will be added programmatically -->
                </StackPanel>

                <!-- Main video display -->
                <Image x:Name="PreviewImage" 
                       Stretch="Uniform"
                       Margin="0,120,0,0"/>

                <TextBlock 
                    x:Name="WaitText"
                    Text="Wait" 
                    FontSize="30" 
                    Foreground="White"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"/>

                <!-- Current speaker name overlay -->
                <Border VerticalAlignment="Bottom" 
                        HorizontalAlignment="Center" 
                        Background="#AA000000" 
                        CornerRadius="4" 
                        Padding="15,8" 
                        Margin="0,0,0,20"
                        x:Name="SpeakerNameBorder"
                        Visibility="Collapsed">
                    <TextBlock x:Name="SpeakerNameText" 
                               Text="Speaker Name" 
                               Foreground="White" 
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Right side: Controls -->
        <ScrollViewer Grid.Column="1" Margin="10" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="15" Margin="0,0,10,20">

            <!-- Source Selection ComboBox -->
            <TextBlock Text="Recording Source:" FontWeight="SemiBold" Margin="0,10,0,5"/>
            <ComboBox x:Name="SourceComboBox" 
                      HorizontalAlignment="Stretch"
                      SelectionChanged="SourceComboBox_SelectionChanged">
                <ComboBoxItem Content="Screen Recording" Tag="Screen" IsSelected="True"/>
            </ComboBox>

            <!-- Refresh Button -->
            <Button x:Name="RefreshButton" 
                    Content="Refresh Cameras" 
                    HorizontalAlignment="Stretch"
                    Click="RefreshButton_Click"/>

            <!-- File Settings -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Padding="10"
                    Margin="0,10,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="File Settings:" FontWeight="SemiBold"/>

                    <!-- Filename Input -->
                    <TextBlock Text="Filename:" FontSize="12"/>
                    <TextBox x:Name="FilenameTextBox" 
                             PlaceholderText="Enter filename"
                             Text="Recording"/>

                    <!-- Auto Date/Time Checkbox -->
                    <CheckBox x:Name="AutoDateTimeCheckBox" 
                              Content="Automatically add date and time"
                              IsChecked="True"/>

                    <!-- Save Location -->
                    <Button x:Name="ChooseLocationButton" 
                            Content="Choose Save Location" 
                            HorizontalAlignment="Stretch"
                            Click="ChooseLocationButton_Click"/>

                    <TextBlock x:Name="SaveLocationText" 
                               Text="Location: Not set" 
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Record/Stop Button -->
            <Button x:Name="RecordButton" 
                    Content="Record" 
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Padding="20,15"
                    Click="RecordButton_Click"/>

            <!-- Video Call Section -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Padding="10"
                    Margin="0,10,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Video Call:" FontWeight="SemiBold"/>

                    <!-- Host/Connect Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="HostButton" 
                                Content="Host" 
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,5,0"
                                Click="HostButton_Click"/>

                        <Button x:Name="ConnectButton" 
                                Content="Connect" 
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Margin="5,0,0,0"
                                Click="ConnectButton_Click"/>
                    </Grid>

                    <!-- IP Address Input -->
                    <TextBlock Text="Host IP Address:" FontSize="12"/>
                    <TextBox x:Name="IpAddressTextBox" 
                             PlaceholderText="192.168.1.100"
                             MaxLength="15"/>

                    <!-- Your IP Display -->
                    <TextBlock x:Name="YourIpText" 
                               Text="Your IP: Not available" 
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <!-- Disconnect Button -->
                    <Button x:Name="DisconnectButton" 
                            Content="Disconnect" 
                            HorizontalAlignment="Stretch"
                            IsEnabled="False"
                            Click="DisconnectButton_Click"/>

                    <!-- Participants List -->
                    <TextBlock x:Name="ParticipantsText" 
                               Text="Participants: 0" 
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Microphone Controls -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Padding="10"
                    Margin="0,10,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Microphone:" FontWeight="SemiBold"/>

                    <!-- Microphone Selection -->
                    <ComboBox x:Name="MicrophoneComboBox" 
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Select microphone"
                              SelectionChanged="MicrophoneComboBox_SelectionChanged"/>

                    <!-- Mute Button -->
                    <ToggleButton x:Name="MuteToggleButton" 
                                  HorizontalAlignment="Stretch"
                                  Click="MuteToggleButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="MicIcon" Glyph="&#xE720;" FontSize="16"/>
                            <TextBlock x:Name="MuteButtonText" Text="Mute"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Voice Activity Indicator -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Ellipse x:Name="VoiceActivityIndicator" 
                                 Width="12" 
                                 Height="12" 
                                 Fill="Gray"/>
                        <TextBlock x:Name="VoiceActivityText" 
                                   Text="Not speaking" 
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status Text -->
            <TextBlock x:Name="StatusText" 
                       Text="Ready" 
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
